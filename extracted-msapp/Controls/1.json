        "Property": "OnStart",
        "Category": "Behavior",
        "InvariantScript": "Set(varLoading, true);\r\n\r\n// ── 1) Parâmetros de URL ────────────────────────────────────────────────────\r\nSet(gParamServicoId, Coalesce(Param(\"servicoId\"), \"\"));\r\nSet(gParamConsumed, false);\r\nSet(gParamTipo, Coalesce(Param(\"tipo\"), \"\"));\r\nSet(varErroApp, \"\");\r\n\r\n// ── 2) Identificar Motorista Logado ─────────────────────────────────────────\r\nSet(\r\n    varMotoristaUser,\r\n    IfError(\r\n        LookUp(Funcionários, 'Email Microsoft' = User().Email),\r\n        Blank()\r\n    )\r\n);\r\nIf(\r\n    IsBlank(varMotoristaUser),\r\n    Set(varErroApp, \"Usuário não encontrado no banco de dados. Entre em contato com o suporte Betinhos.\")\r\n);\r\n\r\n\r\nSet(varLoading, false);",
